# 最初にすべての階層のファイルを無視
### all ignore ###
/*
/.**
*/.**

### not ignore ###
!/.xprofile

# shell
!/.bashrc
!!/zsh/
!/zsh/*
/!/fish/
!/fish/config.fish
!/nushell/
!/nushell/config.nu

!/conky.conf
!/starship.toml

# editor
!/nvim/
!/nvim/*/
!/nvim-jetpack/
!/nvim-jetpack/*/
!/nvim-lazy/
!/nvim-lazy/*/
!/nvim-win/
!/nvim-win/*

# coding agent
!/codex/
!/codex/skills/
!/codex/skills/**

# OS
!/windows/
!/windows/*
!/windows/**
!/nixos/
!/nixos/flake.nix
!/nixos/flake.lock
!/nixos/home/wsl-nixos.nix
!/nixos/home/mba2013.nix
!/nixos/hosts/wsl-nixos/configration.nix
!/nixos/hosts/mba2013/configration.nix
!/nixos/hosts/mba2013/hardware-configration.nix

# device 
!/device/
!/device/kbd/
!/device/kbd/googleIME/
!/device/kbd/googleIME/*
!/device/kbd/HHKB/
!/device/kbd/HHKB/*.hks

!/README.md
!.gitignore
