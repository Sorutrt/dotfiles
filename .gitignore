# 最初にすべての階層のファイルを無視
### all ignore ###
/*
/.**
*/.**

### not ignore ###
!/.xprofile

# GitHub Actions
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml

# shell
!/.bashrc
!!/zsh/
!/zsh/*
/!/fish/
!/fish/config.fish
!/nushell/
!/nushell/config.nu

!/conky.conf
!/starship.toml

# editor
!/nvim/
!/nvim/*/
!/nvim-jetpack/
!/nvim-jetpack/*/
!/nvim-lazy/
!/nvim-lazy/*/
!/nvim-win/
!/nvim-win/*

# coding agent
!/codex/
!/codex/AGENTS.md
!/codex/rules/
!/codex/rules/*
!/codex/skills/
!/codex/skills/**

# OS
!/windows/
!/windows/*
!/windows/**
!/flake.nix
!/flake.lock
!/overlays/
!/overlays/*.nix
!/home/
!/home/*
!/hosts/
!/hosts/*

# device 
!/device/
!/device/kbd/
!/device/kbd/googleIME/
!/device/kbd/googleIME/*
!/device/kbd/HHKB/
!/device/kbd/HHKB/*.hks

# GUI
!/hypr/
!/hypr/hyprland.lua
!/copyq/
!/copyq/copyq.conf
!/niri/
!/niri/config.kdl
!/waybar/
!/waybar/config.jsonc
!/waybar/style.css
!/foot/
!/foot/foot.ini
!/mako/
!/mako/config

!/README.md
!/AGENTS.md
!.gitignore
